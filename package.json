{
  "name": "my-blog",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt generate",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "i18n:ui": "tsx scripts/i18n-generate-ui.ts",
    "i18n:ui:translate": "tsx scripts/i18n-translate-ui.ts",
    "i18n:gen": "tsx scripts/i18n-generate.ts",
    "i18n:translate": "tsx scripts/i18n-generate.ts --translate",
    "i18n:translate:all": "npm run i18n:translate && npm run i18n:ui:translate",
    "i18n:check": "tsx scripts/i18n-check.ts",
    "i18n:generate": "npm run i18n:gen",
    "wiki:check": "tsx scripts/wiki-check.ts",
    "music:cdn-map": "node scripts/music-cdn-map.mjs",
    "prebuild": "npm run wiki:check && npm run i18n:ui && npm run i18n:gen",
    "pregenerate": "npm run wiki:check && npm run i18n:ui && npm run i18n:gen",
    "preview": "nuxt preview"
  },
  "dependencies": {
    "@edgeone/pages-blob": "^0.0.14",
    "@nuxt/content": "^3.14.0",
    "better-sqlite3": "^12.10.0",
    "medium-zoom": "^1.1.0",
    "nuxt": "^4.4.7",
    "opencc-js": "^1.3.1",
    "pinyin-pro": "^3.28.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "tsx": "^4.22.4"
  }
}
